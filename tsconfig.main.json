{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "electron"],
    "rootDir": "src/main",
    "outDir": "dist/main",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/main/**/*.ts"]
}
